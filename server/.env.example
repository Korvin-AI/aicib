# Required
DATABASE_URL=postgresql://aicib:CHANGE_ME@localhost:5432/aicib

# Optional (with defaults)
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Anthropic API key (required for running briefs)
# ANTHROPIC_API_KEY=sk-ant-...

# Encryption key for org secrets (64 hex chars). Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# S3-compatible storage (optional, for deliverable uploads)
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# Sentry error tracking (optional)
# SENTRY_DSN=
