# Docker Compose environment variables
# Copy to .env and fill in values before running `docker compose up`

# --- PostgreSQL ---
POSTGRES_PASSWORD=aicib_dev

# --- Server ---
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# Anthropic API key (required for running briefs)
# ANTHROPIC_API_KEY=sk-ant-...

# Encryption key for secrets (64 hex chars). Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# S3-compatible storage (optional, for deliverable uploads)
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# Sentry error tracking (optional)
# SENTRY_DSN=

# --- UI ---
NEXT_PUBLIC_API_URL=http://localhost:3001
